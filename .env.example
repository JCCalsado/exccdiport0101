APP_NAME="CCDI Account Portal"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://exccdiport0101-production-724f.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ccdi_portal
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- QUEUE ---
# Use 'sync' for local dev/testing (emails send immediately, no worker needed).
# Use 'database' for production (requires queue:work to be running).
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- MAIL (Resend) ---
# Set MAIL_MAILER=resend for production.
# Set MAIL_MAILER=log for local dev to inspect emails in storage/logs/laravel.log.
MAIL_MAILER=resend
RESEND_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM_ADDRESS=noreply@ccdi.edu.ph
MAIL_FROM_NAME="${APP_NAME}"

# Legacy SMTP fields (unused when MAIL_MAILER=resend — kept for reference only)
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

TELESCOPE_ENABLED=false

PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
PAYMONGO_WEBHOOK_SECRET=whsk_xxxxxxxxxxxxxxxxxxxxxx

PAYMENT_RETURN_URL=${APP_URL}/payment/success
PAYMENT_CANCEL_URL=${APP_URL}/payment/cancel

# Set to true ONLY when you need to wipe and reseed the database on next deploy.
# Remove or set to false immediately after — leaving it true will wipe data on every restart.
FORCE_RESEED=false